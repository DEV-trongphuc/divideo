/* Keyframes */

@keyframes pulseEye {
    0% {
        transform: scale(0.95);
        box-shadow: 0 0 20px rgba(255, 0, 85, 0.4);
    }

    100% {
        transform: scale(1.05);
        box-shadow: 0 0 45px rgba(255, 0, 85, 0.7);
    }
}

@keyframes blinkLight {
    0% {
        opacity: 0.3;
    }

    100% {
        opacity: 1;
    }
}

@keyframes textFlash {
    0% {
        opacity: 0.6;
    }

    100% {
        opacity: 1;
    }
}

@keyframes glitchText {
    0% {
        text-shadow: 0.05em 0 0 rgba(255, 0, 85, 0.75),
            -0.05em -0.025em 0 rgba(0, 223, 252, 0.75);
    }

    14% {
        text-shadow: 0.05em 0 0 rgba(255, 0, 85, 0.75),
            -0.05em -0.025em 0 rgba(0, 223, 252, 0.75);
    }

    15% {
        text-shadow: -0.05em -0.025em 0 rgba(255, 0, 85, 0.75),
            0.025em 0.035em 0 rgba(0, 223, 252, 0.75);
    }

    49% {
        text-shadow: -0.05em -0.025em 0 rgba(255, 0, 85, 0.75),
            0.025em 0.035em 0 rgba(0, 223, 252, 0.75);
    }

    50% {
        text-shadow: 0.025em 0.05em 0 rgba(255, 0, 85, 0.75),
            0.05em 0 0 rgba(0, 223, 252, 0.75);
    }

    99% {
        text-shadow: 0.025em 0.05em 0 rgba(255, 0, 85, 0.75),
            0.05em 0 0 rgba(0, 223, 252, 0.75);
    }

    100% {
        text-shadow: -0.025em 0 0 rgba(255, 0, 85, 0.75),
            -0.025em -0.025em 0 rgba(0, 223, 252, 0.75);
    }
}

@keyframes bulletStream {
    0% {
        background-position-x: 0px;
    }

    100% {
        background-position-x: 300px;
    }
}

@keyframes pulseDot {
    0% {
        transform: scale(0.9);
        opacity: 0.7;
    }

    100% {
        transform: scale(1.1);
        opacity: 1;
    }
}

@keyframes bounceArrows {

    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(6px);
    }
}

@keyframes shakeDb {
    0% {
        transform: translate(1px, 1px) scale(1);
    }

    50% {
        transform: translate(-1px, -1px) scale(1.05);
    }

    100% {
        transform: translate(1px, 1px) scale(1);
    }
}

