    align-items: center;
    justify-content: center;
    color: #000;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 40px;
    box-shadow: 0 0 35px rgba(245, 158, 11, 0.6);
    z-index: 10;
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.split-vs-badge.active {
