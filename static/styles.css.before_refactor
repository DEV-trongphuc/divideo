/* Pagination Simulation Styles */
.sim-pag-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
}

.sim-pag-table-box {
    width: 90%;
    background: rgba(18, 18, 24, 0.75);
    border: 2px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.sim-pag-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 24px;
}

.sim-pag-table th,
.sim-pag-table td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.sim-pag-table th {
    color: var(--gold-secondary);
    font-weight: 600;
}

.sim-pag-row {
    transition: all 0.3s ease;
}

.sim-pag-row.skipped {
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
    text-decoration: line-through;
    opacity: 0.6;
}

.sim-pag-row.target {
    background: rgba(16, 185, 129, 0.2);
    color: var(--success-green);
    font-weight: bold;
    box-shadow: inset 0 0 15px rgba(16, 185, 129, 0.2);
    animation: pulseRowGlow 1.5s infinite alternate;
}

.sim-pag-row.bypassed {
    opacity: 0.25;
    color: var(--text-muted);
}

.sim-pag-row.scanning {
    background: rgba(245, 158, 11, 0.15);
    color: var(--gold-primary);
    box-shadow: inset 0 0 10px rgba(245, 158, 11, 0.25);
}

@keyframes pulseRowGlow {
    0% {
        box-shadow: inset 0 0 10px rgba(16, 185, 129, 0.2);
    }

    100% {
        box-shadow: inset 0 0 25px rgba(16, 185, 129, 0.5);
    }
}

.sim-pag-telemetry {
