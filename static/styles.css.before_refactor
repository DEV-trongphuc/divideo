    border-radius: 50%;
}

.sim-server-rack-small {
    background: rgba(18, 18, 24, 0.85);
    border: 2px dashed rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
}

.sim-server-lights {
    display: flex;
    gap: 6px;
}

.sim-server-lights .light {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
}

.sim-server-lights .light.active {
    background: #10b981;
    box-shadow: 0 0 8px #10b981;
    animation: blinkLight 0.5s infinite alternate;
}

.sim-server-lights .light.active:nth-child(2) {
    animation-delay: 0.15s;
}

.sim-server-lights .light.active:nth-child(3) {
    animation-delay: 0.3s;
}

.sim-monster-text {
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 900;
    color: #ff0055;
    letter-spacing: 4px;
    text-shadow: 0 0 15px rgba(255, 0, 85, 0.5);
}

/* Speedometer Dial */
.sim-speedometer-box {
    width: 90%;
    max-width: 440px;
    padding: 30px;
    text-align: center;
    border-radius: 16px;
}

.speedometer-gauge {
    position: relative;
    width: 240px;
    height: 120px;
    margin: 0 auto 20px auto;
    border-top-left-radius: 120px;
    border-top-right-radius: 120px;
    background: linear-gradient(180deg, rgba(239, 68, 68, 0.1) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 3px solid rgba(255, 255, 255, 0.08);
    border-bottom: none;
    overflow: hidden;
}

.speedometer-needle {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 4px;
    height: 100px;
    background: #ef4444;
    border-radius: 2px;
    transform-origin: bottom center;
    transform: rotate(0deg);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 0 10px #ef4444;
    z-index: 2;
}

.speedometer-needle::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: -6px;
    width: 16px;
    height: 16px;
    background: #fff;
    border-radius: 50%;
    border: 3px solid #ef4444;
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.5);
}

.speedometer-labels {
    position: absolute;
    bottom: 8px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 15px;
    font-size: 24px;
    font-weight: 800;
}

.speed-good {
    color: #10b981;
}

.speed-bad {
    color: #ef4444;
}

.speedometer-value {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 8px;
}

.speedometer-sub {
    font-size: 22px;
}

/* Glitch Title */
.sim-glitch-container {
    text-align: center;
}

.glitch-title {
    font-size: 64px;
    font-weight: 950;
    color: #fff;
    position: relative;
    text-shadow: 0.05em 0 0 rgba(255, 0, 85, 0.75),
        -0.025em -0.05em 0 rgba(0, 223, 252, 0.75),
        0.025em 0.05em 0 rgba(255, 239, 0, 0.75);
    animation: glitchText 500ms infinite;
}

.glitch-subtitle {
    font-size: 24px;
    color: var(--text-muted);
    letter-spacing: 2px;
    margin-top: 10px;
}

/* Server Health Dial */
.sim-server-health-box {
    width: 90%;
    max-width: 440px;
    padding: 24px;
}

.sim-health-dial {
    width: 150px;
