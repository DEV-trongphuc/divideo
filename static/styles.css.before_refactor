/* --- Follow CTA Animation on Last Slide --- */
.follow-cta-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 40px;
    width: 100%;
    animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.follow-avatar-wrapper {
    position: relative;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 3px solid var(--gold-primary);
    background: #000;
    padding: 3px;
    box-shadow: 0 10px 25px rgba(245, 158, 11, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
}

.follow-avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
}

/* Red Plus follow button */
.follow-plus-btn {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translate(-50%, 0) scale(1);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, #FF0050 0%, #EF2F5F 100%);
    /* TikTok red follow color */
    border: 2px solid #08080a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 24px;
    box-shadow: 0 4px 10px rgba(239, 47, 95, 0.4);
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 10;
}

.follow-plus-btn svg {
    width: 22px;
    height: 22px;
    stroke-width: 3px;
}

/* Ripple expand wave */
.follow-ripple-ring {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 2px solid var(--gold-primary);
    opacity: 0;
    pointer-events: none;
}

/* Followed state animations */
.follow-cta-container.is-followed .follow-plus-btn {
    background: #10B981;
    /* Success Green */
    transform: translate(-50%, 0) scale(0.9) rotate(360deg);
    box-shadow: 0 4px 10px rgba(16, 185, 129, 0.4);
}

.follow-cta-container.is-followed .follow-ripple-ring {
    animation: followRipple 0.8s ease-out forwards;
}

@keyframes followRipple {
    0% {
        transform: scale(1);
        opacity: 1;
        border-color: #10B981;
    }

    100% {
        transform: scale(1.5);
        opacity: 0;
        border-color: rgba(16, 185, 129, 0);
    }
}

.follow-text {
    font-size: 32px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 24px;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
}

.follow-cta-container.is-followed .follow-text {
    color: var(--gold-secondary);
    text-shadow: 0 0 10px rgba(245, 158, 11, 0.2);
}

