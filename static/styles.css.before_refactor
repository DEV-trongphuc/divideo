/* Template 13: Hook & Transition Layout */
.layout-transition-view {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    height: 100%;
    padding: 80px 40px;
    text-align: center;
}

.transition-user-header {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 12px 24px;
    border-radius: 9999px;
    opacity: 0;
    transform: translateY(-20px);
    animation: slideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.transition-user-avatar {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--gold-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    color: #000;
    font-size: 28px;
}

.transition-user-handle {
    font-size: 28px;
    font-weight: 600;
    color: var(--text-muted);
}

.transition-user-handle span {
    color: var(--gold-primary);
}

.transition-title-box {
    margin: auto 0;
    opacity: 0;
    transform: scale(0.95);
    animation: scaleIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards 0.2s;
}

.transition-title-box h1 {
    font-size: 56px;
    font-weight: 900;
    line-height: 1.3;
    background: linear-gradient(135deg, #fff 0%, var(--gold-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    margin-bottom: 40px;
}

.layout-transition-view.transition-theme-danger {
    position: relative;
    overflow: hidden;
    background: radial-gradient(circle, #180202 0%, #030000 100%) !important;
}

.layout-transition-view.transition-theme-danger::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.3) 50%), linear-gradient(90deg, rgba(239, 68, 68, 0.05), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.04));
    background-size: 100% 6px, 8px 100%;
    z-index: 1;
    pointer-events: none;
    animation: dangerScanlines 0.15s infinite linear;
}

.layout-transition-view.transition-theme-danger::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    box-shadow: inset 0 0 120px rgba(239, 68, 68, 0.45);
    z-index: 2;
    pointer-events: none;
    animation: dangerVignettePulse 1.2s infinite ease-in-out;
}

.layout-transition-view.transition-theme-danger>* {
    position: relative;
    z-index: 10;
}

@keyframes dangerScanlines {
    0% {
        background-position: 0 0, 0 0;
    }

    100% {
        background-position: 0 6px, 0 0;
    }
}

@keyframes dangerVignettePulse {

    0%,
    100% {
        box-shadow: inset 0 0 100px rgba(239, 68, 68, 0.4);
        background: rgba(239, 68, 68, 0.01);
    }

    50% {
        box-shadow: inset 0 0 240px rgba(239, 68, 68, 0.85);
        background: rgba(239, 68, 68, 0.04);
    }
}

@keyframes dangerTextGlitch {

    0%,
    100% {
        text-shadow: 0 0 10px rgba(239, 68, 68, 0.6);
        transform: translate(0, 0);
    }

    45% {
        text-shadow: 0 0 10px rgba(239, 68, 68, 0.6);
        transform: translate(0, 0);
    }

    48% {
        text-shadow: -4px -2px 0px rgba(0, 255, 255, 0.75), 4px 2px 0px rgba(255, 0, 255, 0.75), 0 0 25px rgba(239, 68, 68, 0.9);
        transform: translate(-2px, 1px);
    }

    51% {
        text-shadow: 4px -3px 0px rgba(0, 255, 255, 0.75), -4px 3px 0px rgba(255, 0, 255, 0.75), 0 0 25px rgba(239, 68, 68, 0.9);
        transform: translate(3px, -1px);
    }

    54% {
        text-shadow: 0 0 10px rgba(239, 68, 68, 0.6);
        transform: translate(0, 0);
    }
}

.transition-theme-danger .transition-title-box h1 {
    background: linear-gradient(135deg, #fff 0%, var(--warning-red) 100%);
    -webkit-background-clip: text;
    animation: dangerTextGlitch 2s infinite linear;
}

.transition-theme-success .transition-title-box h1 {
    background: linear-gradient(135deg, #fff 0%, var(--success-green) 100%);
    -webkit-background-clip: text;
}

.transition-theme-info .transition-title-box h1 {
    background: linear-gradient(135deg, #fff 0%, #3b82f6 100%);
    -webkit-background-clip: text;
}

.transition-large-icon-wrapper {
    width: 180px;
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30px auto;
    position: relative;
}

.transition-large-icon-wrapper svg {
    width: 140px !important;
    height: 140px !important;
    stroke-width: 1.5px;
}

.transition-theme-warning .transition-large-icon-wrapper {
    background: none;
    border: none;
    color: var(--gold-primary);
    animation: transitionPulseGold 2.5s infinite ease-in-out;
}

.transition-theme-danger .transition-large-icon-wrapper {
    background: none;
    border: none;
    color: var(--warning-red);
    animation: transitionPulseRed 1.6s infinite ease-in-out;
}

.transition-theme-success .transition-large-icon-wrapper {
    background: none;
    border: none;
    color: var(--success-green);
    animation: transitionPulseGreen 2.5s infinite ease-in-out;
}

.transition-theme-info .transition-large-icon-wrapper {
    background: none;
    border: none;
    color: #3b82f6;
    animation: transitionPulseBlue 2.5s infinite ease-in-out;
}

@keyframes transitionPulseGold {

    0%,
    100% {
        transform: scale(1);
        filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.4));
    }

    50% {
        transform: scale(1.1);
        filter: drop-shadow(0 0 25px rgba(245, 158, 11, 0.8));
    }
}

@keyframes transitionPulseRed {

    0%,
    100% {
        transform: scale(1) translate(0, 0);
        filter: drop-shadow(0 0 12px rgba(239, 68, 68, 0.5));
    }

    47% {
        transform: scale(1.05) translate(0, 0);
        filter: drop-shadow(0 0 20px rgba(239, 68, 68, 0.7));
    }

    50% {
        transform: scale(1.08) translate(-4px, 2px) rotate(-1deg);
        filter: drop-shadow(0 0 35px rgba(239, 68, 68, 0.95)) drop-shadow(0 0 50px rgba(239, 68, 68, 0.5));
    }

    53% {
        transform: scale(1.08) translate(4px, -2px) rotate(1deg);
        filter: drop-shadow(0 0 35px rgba(239, 68, 68, 0.95)) drop-shadow(0 0 50px rgba(239, 68, 68, 0.5));
    }

    56% {
        transform: scale(1.05) translate(0, 0);
        filter: drop-shadow(0 0 20px rgba(239, 68, 68, 0.7));
    }
}

@keyframes transitionPulseGreen {

    0%,
    100% {
        transform: scale(1);
        filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.4));
