/* Table dynamic scanning styling */
.studio-data-table tr.scanned-failed {
    opacity: 0.35;
    color: rgba(255, 255, 255, 0.3);
    transition: opacity 0.3s ease;
}

@keyframes rowGlow {
    0% {
        background: rgba(245, 158, 11, 0.08) !important;
        box-shadow: inset 4px 0 0 var(--gold-primary) !important;
    }

    50% {
        background: rgba(245, 158, 11, 0.22) !important;
        box-shadow: inset 6px 0 15px rgba(245, 158, 11, 0.35) !important;
    }

    100% {
        background: rgba(245, 158, 11, 0.08) !important;
        box-shadow: inset 4px 0 0 var(--gold-primary) !important;
    }
}

@keyframes rowGlowSuccess {
    0% {
        background: rgba(16, 185, 129, 0.08) !important;
        box-shadow: inset 4px 0 0 var(--success-green) !important;
    }

    50% {
        background: rgba(16, 185, 129, 0.22) !important;
        box-shadow: inset 6px 0 15px rgba(16, 185, 129, 0.35) !important;
    }

    100% {
        background: rgba(16, 185, 129, 0.08) !important;
        box-shadow: inset 4px 0 0 var(--success-green) !important;
    }
}

.studio-data-table tr.scanning-active {
    animation: rowGlow 1.2s ease-in-out infinite;
}

.studio-data-table tr.scanning-active.highlight-success {
    animation: rowGlowSuccess 1.2s ease-in-out infinite;
}

/* Animated dot moving down the active diagram arrow connection path */
.diagram-arrow.active .diagram-data-packet {
    position: absolute;
    width: 12px;
    height: 12px;
    background: var(--gold-primary);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--gold-primary), 0 0 20px var(--gold-primary);
    left: 50%;
    transform: translateX(-50%);
    top: -15px;
    animation: flowDown 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    opacity: 0;
    z-index: 10;
}

@keyframes flowDown {
    0% {
        top: -15px;
        opacity: 0;
        transform: translateX(-50%) scale(0.6);
    }

    20% {
        opacity: 1;
        transform: translateX(-50%) scale(1);
    }

    80% {
        opacity: 1;
        transform: translateX(-50%) scale(1);
    }

    100% {
        top: calc(100% + 5px);
        opacity: 0;
        transform: translateX(-50%) scale(0.6);
    }
}

.box-slot-item {
