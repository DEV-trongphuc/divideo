/* Template 8: Index Tree Layout (B-Tree Visualizer) */
.layout-tree-view {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 40px;
    height: 100%;
}

.tree-header {
    text-align: center;
    margin-bottom: 30px;
    opacity: 0;
    transform: translateY(50px);
    animation: premiumTextReveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.tree-header h2 {
    font-size: 40px;
    font-weight: 800;
    margin: 15px 0 10px;
}

.tree-header p {
    font-size: 18px;
    color: var(--text-muted);
}

.tree-container {
    flex: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    width: 100%;
    margin-top: 0;
    height: 500px;
}

.tree-node {
    background: var(--bg-card);
    border: 2px solid var(--border-color);
    padding: 18px 28px;
    border-radius: 12px;
    font-size: 22px;
    font-weight: 600;
    text-align: center;
    color: var(--text-primary);
    position: absolute;
    min-width: 220px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 10;
}

/* Node Positions */
.tree-node.root-node {
    top: 5%;
    left: calc(50% - 110px);
    animation: scaleIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

.tree-node.left-node {
    top: 38%;
    left: calc(25% - 110px);
    animation: scaleIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards 0.2s;
}

.tree-node.right-node {
    top: 38%;
    left: calc(75% - 110px);
    animation: scaleIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards 0.25s;
}

.tree-node.target-node {
    top: 75%;
    left: calc(25% - 110px);
    animation: scaleIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards 0.4s;
}

/* Node States */
.tree-node.highlighted {
    border-color: var(--gold-primary);
    box-shadow: 0 0 25px rgba(245, 158, 11, 0.3);
    color: var(--gold-secondary);
}

.tree-node.dimmed {
    opacity: 0.25;
    border-style: dashed;
    filter: grayscale(80%);
}

.tree-node.success {
    border-color: var(--success-green);
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.45);
    background: rgba(16, 185, 129, 0.15);
    color: #fff;
}

