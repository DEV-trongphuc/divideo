/* Design System & Global Variables */
:root {
    --bg-darker: #050507;
    --bg-dark: #0d0d11;
    --bg-card: rgba(18, 18, 24, 0.75);
    --border-color: rgba(245, 158, 11, 0.12);
    --border-color-hover: rgba(245, 158, 11, 0.3);
    --gold-primary: #F59E0B;
    --gold-secondary: #FEF08A;
    --gold-glow: rgba(245, 158, 11, 0.15);
    --text-primary: #F3F4F6;
    --text-muted: #9CA3AF;
    --text-gold: #FCD34D;
    --font-sans: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    --font-mono: 'Fira Code', monospace;
    --success-green: #10B981;
    --warning-red: #EF4444;
}

/* Global Reset */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-darker);
    color: var(--text-primary);
    font-family: var(--font-sans);
    height: 100vh;
    overflow: hidden;
}

/* App Layout Grid */
.app-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
}

/* Header */
.app-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 24px;
    background-color: var(--bg-dark);
    border-bottom: 1px solid var(--border-color);
    z-index: 100;
}

.logo-area {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
}

.logo-gold-glow {
    position: absolute;
    width: 32px;
    height: 32px;
    background: radial-gradient(circle, var(--gold-primary) 0%, transparent 70%);
    opacity: 0.5;
    left: -8px;
    top: -4px;
    filter: blur(4px);
}

.logo-tag {
    font-weight: 800;
    color: var(--gold-primary);
    letter-spacing: 0.05em;
    font-size: 1.1rem;
}

.logo-title {
    font-size: 0.9rem;
    color: var(--text-muted);
    border-left: 1px solid rgba(255, 255, 255, 0.15);
    padding-left: 12px;
}

.system-status {
    display: flex;
    align-items: center;
    gap: 12px;
}

/* Badges */
.badge {
    padding: 4px 10px;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
}

.badge.success {
    background-color: rgba(16, 185, 129, 0.15);
    color: var(--success-green);
    border: 1px solid rgba(16, 185, 129, 0.3);
}

.badge.warning {
    background-color: rgba(245, 158, 11, 0.15);
    color: var(--gold-primary);
    border: 1px solid rgba(245, 158, 11, 0.3);
}

/* Buttons */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 1px solid transparent;
}

.btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
}

.btn-sm {
    padding: 4px 10px;
    font-size: 0.8rem;
}

.btn-large {
    padding: 10px 20px;
    font-size: 1rem;
}

.btn-block {
    display: flex;
    width: 100%;
}

.btn-primary {
    background-color: var(--gold-primary);
    color: #000;
}

.btn-primary:hover {
    background-color: var(--gold-secondary);
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.4);
}

.btn-secondary {
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    border: 1px solid rgba(255, 255, 255, 0.1);
}

.btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
}

.btn-danger {
    background-color: rgba(239, 68, 68, 0.2);
    color: #F87171;
    border: 1px solid rgba(239, 68, 68, 0.4);
}

.btn-danger:hover {
    background-color: rgba(239, 68, 68, 0.4);
}

.btn-success {
    background-color: rgba(16, 185, 129, 0.2);
    color: #34D399;
    border: 1px solid rgba(16, 185, 129, 0.4);
}

.btn-success:hover {
    background-color: rgba(16, 185, 129, 0.4);
}

.btn-gold {
    background: linear-gradient(135deg, var(--gold-primary) 0%, #D97706 100%);
    color: #000;
    font-weight: 600;
}

.btn-gold:hover {
    filter: brightness(1.1);
    box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
}

/* App Body Split */
.app-body {
    display: grid;
    grid-template-columns: 460px 1fr;
    flex: 1;
    overflow: hidden;
}

/* Panels */
.sidebar-panel {
    background-color: var(--bg-dark);
    border-right: 1px solid var(--border-color);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow-y: auto;
}

.preview-panel {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-darker);
    overflow: hidden;
    position: relative;
}

/* Section Cards */
.section-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 16px;
    backdrop-filter: blur(12px);
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.section-header h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--gold-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* Form Controls */
.form-group {
    margin-bottom: 12px;
}

.form-group label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 4px;
}

.form-control {
    width: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 8px 12px;
    color: #fff;
    font-family: inherit;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
}

.form-control:focus {
    border-color: var(--gold-primary);
    box-shadow: 0 0 6px rgba(245, 158, 11, 0.2);
}

textarea.form-control {
    resize: none;
}

.code-textarea {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background-color: #050505;
}

/* Slide Editor Details */
.slide-id-tag {
    background: rgba(245, 158, 11, 0.15);
    color: var(--gold-primary);
    border: 1px solid var(--border-color);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
}

.editor-divider {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
    margin: 16px 0;
}

/* Layout Selector Buttons */
.layout-selector {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
}

.layout-btn {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 8px 4px;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.75rem;
    transition: all 0.2s ease;
}

.layout-btn:hover {
    border-color: var(--border-color-hover);
    color: var(--text-primary);
}

.layout-btn.active {
    background: rgba(245, 158, 11, 0.1);
    border-color: var(--gold-primary);
    color: var(--gold-secondary);
}

.layout-btn i {
    width: 18px;
    height: 18px;
}

/* Slide List Elements */
.slide-list-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 150px;
    overflow-y: auto;
    padding-right: 4px;
}

.slide-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 8px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
}

.slide-item:hover {
    background: rgba(255, 255, 255, 0.05);
}

.slide-item.active {
    background: rgba(245, 158, 11, 0.05);
    border-color: var(--gold-primary);
    box-shadow: inset 0 0 10px rgba(245, 158, 11, 0.05);
}

.slide-item-info {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
}

.slide-item-index {
    color: var(--gold-primary);
    font-weight: 700;
    font-size: 0.8rem;
}

.slide-item-title {
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #e5e7eb;
}

.slide-item-actions {
    display: flex;
    align-items: center;
    gap: 6px;
}

.slide-item-layout {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    padding: 1px 5px;
    border-radius: 4px;
    text-transform: uppercase;
}

.slide-delete-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 2px;
    display: flex;
    border-radius: 4px;
}

.slide-delete-btn:hover {
    color: var(--warning-red);
    background: rgba(239, 68, 68, 0.1);
}

/* Voice Cloning Elements */
.voice-cloning-section {
    background: rgba(0, 0, 0, 0.3);
    border-radius: 8px;
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    margin-bottom: 12px;
}

.voice-record-container {
    margin-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 10px;
}

.voice-record-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 6px;
}

.record-status-label {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.voice-upload-row {
    display: flex;
    gap: 8px;
    margin-top: 8px;
}

/* Nodes Editor */
.nodes-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 6px;
}

.node-edit-row {
    display: flex;
    gap: 6px;
    align-items: center;
}

.node-edit-row input {
    flex: 1;
}

.node-edit-row select {
    width: 90px;
}

.node-delete-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
}

/* Cards Editor */
.cards-editor {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 6px;
}

.card-edit-block {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    padding: 8px;
}

/* 16:9 Canvas Frame & Scaler */
.canvas-outer-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: #08080a;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
    width: 100%;
    flex: 1;
    overflow: hidden;
    position: relative;
}

.aspect-ratio-header {
    display: flex;
    justify-content: space-between;
    width: 100%;
    padding: 0 8px 8px 8px;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
}

.preview-title i {
    display: inline-block;
    width: 12px;
    height: 12px;
    vertical-align: middle;
    margin-right: 4px;
}

.watermark {
    color: var(--gold-primary);
    font-weight: 700;
}

.canvas-scaler {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    width: 100%;
    overflow: hidden;
}

/* Fixed 9:16 TikTok video canvas (1080x1920 design resolution) */
.video-canvas-16_9 {
    width: 1080px;
    height: 1920px;
    flex-shrink: 0;
    background-color: var(--bg-darker);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 100px 80px;
    box-shadow: 0 0 100px rgba(0, 0, 0, 0.8);
    transform-origin: center center;
    user-select: none;
    border-radius: 24px;
}

/* Background Grid Overlay */
.grid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-size: 50px 50px;
    background-image:
        linear-gradient(to right, rgba(245, 158, 11, 0.075) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(245, 158, 11, 0.075) 1px, transparent 1px);
    z-index: 1;
    pointer-events: none;
}

/* Ambient Radial Glow Spots */
.ambient-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(150px);
    z-index: 2;
    pointer-events: none;
    opacity: 0.85;
}

.glow-1 {
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(245, 158, 11, 0.22) 0%, transparent 70%);
    top: -200px;
    right: -100px;
    animation: floatGlow1 15s ease-in-out infinite;
}

.glow-2 {
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(217, 119, 6, 0.15) 0%, transparent 70%);
    bottom: -300px;
    left: -200px;
    animation: floatGlow2 20s ease-in-out infinite;
}

.glow-3 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(217, 119, 6, 0.18) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: pulseGlow3 12s ease-in-out infinite;
}

@keyframes floatGlow1 {

    0%,
    100% {
        transform: translate(0, 0) scale(1);
    }

    50% {
        transform: translate(-40px, 50px) scale(1.1);
    }
}

@keyframes floatGlow2 {

    0%,
    100% {
        transform: translate(0, 0) scale(1);
    }

    50% {
        transform: translate(50px, -45px) scale(0.95);
    }
}

@keyframes pulseGlow3 {

    0%,
    100% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.5;
    }

    50% {
        transform: translate(-50%, -50%) scale(1.2);
        opacity: 0.7;
    }
}

/* Canvas Header overlay */
.canvas-header {
    position: absolute;
    top: 50px;
    left: 100px;
    right: 100px;
    display: flex;
    justify-content: space-between;
    font-size: 26px; /* Reverted to normal size per user request */
    font-weight: 600;
    color: var(--text-muted);
    border-bottom: 2px solid rgba(255, 255, 255, 0.06);
    padding-bottom: 12px;
    z-index: 10;
    letter-spacing: 0.1em;
}

.header-ep {
    color: var(--gold-secondary);
}

.header-topic {
    color: var(--gold-primary);
    cursor: pointer;
    transition: all 0.2s ease;
    border-bottom: 1.5px dashed rgba(245, 158, 11, 0.4);
    padding-bottom: 2px;
}

.header-topic:hover {
    color: var(--gold-secondary);
    text-shadow: 0 0 10px rgba(245, 158, 11, 0.6);
    border-bottom-color: var(--gold-secondary);
}

/* Fullscreen mode layout overrides */
#canvas-scaler-box:fullscreen {
    background-color: #050507 !important;
    width: 100vw !important;
    height: 100vh !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 !important;
    margin: 0 !important;
    overflow: hidden !important;
}

/* Canvas Footer overlay */
.canvas-footer {
    position: absolute;
    bottom: 50px;
    left: 100px;
    right: 100px;
    display: flex;
    justify-content: space-between;
    /* Visualizer on left, handle on right */
    align-items: center;
    border-top: 2px solid rgba(255, 255, 255, 0.06);
    padding-top: 15px;
    z-index: 10;
}

.footer-handle {
    font-size: 24px;
    font-weight: 700;
    color: var(--gold-primary);
    letter-spacing: 0.05em;
}

/* Live Dynamic Audio Visualizer */
.visualizer-container {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    height: 50px;
    /* Increased height for taller, more energetic wave motion */
}

.visualizer-bar {
    width: 8px;
    /* Thicker and bolder bars for a premium chunkier aesthetic */
    height: 8px;
    background-color: var(--gold-primary);
    border-radius: 3px;
    transition: none;
    /* Let JS Lerp handle smooth 60fps animations without transitions lag */
}

/* Injected Slide Contents Container */
.slide-content-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 10;
    margin-top: 65px;
    /* Pushed titles down from the top header overlay */
    margin-bottom: 40px;
    position: relative;
    width: 100%;
    height: 100%;
}

/* New Animations for Premium Feel */
@keyframes arrowPulse {

    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(8px);
    }
}

@keyframes activeNodeGlow {

    0%,
    100% {
        box-shadow: 0 0 25px rgba(245, 158, 11, 0.2);
        border-color: rgba(245, 158, 11, 0.5);
    }

    50% {
        box-shadow: 0 0 45px rgba(245, 158, 11, 0.45);
        border-color: var(--gold-primary);
    }
}

@keyframes successNodeGlow {

    0%,
    100% {
        box-shadow: 0 0 25px rgba(16, 185, 129, 0.2);
        border-color: rgba(16, 185, 129, 0.5);
    }

    50% {
        box-shadow: 0 0 45px rgba(16, 185, 129, 0.45);
        border-color: var(--success-green);
    }
}

@keyframes warningNodeGlow {

    0%,
    100% {
        box-shadow: 0 0 25px rgba(239, 68, 68, 0.2);
        border-color: rgba(239, 68, 68, 0.5);
    }

    50% {
        box-shadow: 0 0 45px rgba(239, 68, 68, 0.45);
        border-color: #EF4444;
    }
}

@keyframes blinkCursor {

    from,
    to {
        opacity: 1;
    }

    50% {
        opacity: 0;
    }
}

@keyframes iconPop {
    0% {
        transform: scale(0.5);
        opacity: 0;
    }

    70% {
        transform: scale(1.2);
        opacity: 1;
    }

    100% {
        transform: scale(1);
    }
}

@keyframes cardAppear {
    0% {
        opacity: 0;
        transform: translateY(35px) scale(0.96);
    }

    100% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@keyframes metricAppear {
    0% {
        opacity: 0;
        transform: translateY(30px) scale(0.92);
    }

    100% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@keyframes numberPop {
    0% {
        transform: scale(0.85);
        filter: brightness(1.5);
    }

    100% {
        transform: scale(1);
        filter: brightness(1);
    }
}

@keyframes spinIcon {
    0% {
        transform: rotate(-30deg) scale(0.8);
        opacity: 0;
    }

    100% {
        transform: rotate(0) scale(1);
        opacity: 1;
    }
}

@keyframes slideUpFade {
    0% {
        opacity: 0;
        transform: translateY(40px);
    }

    100% {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes scaleIn {
    0% {
        opacity: 0;
        transform: scale(0.96);
    }

    100% {
        opacity: 1;
        transform: scale(1);
    }
}

@keyframes scaleWidth {
    0% {
        transform: scaleX(0);
    }

    100% {
        transform: scaleX(1);
    }
}

/* Premium Transitions & Easing Additions */
@keyframes springDrop {
    0% {
        opacity: 0;
        transform: translateY(-200px) scale(0.5);
    }

    60% {
        opacity: 1;
        transform: translateY(10px) scale(1.05);
    }

    80% {
        transform: translateY(-5px) scale(0.98);
    }

    100% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@keyframes premiumTextReveal {
    0% {
        opacity: 0;
        clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0 100%);
        transform: translateY(100%);
    }

    100% {
        opacity: 1;
        clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
        transform: translateY(0);
    }
}

@keyframes editorTiltIn {
    0% {
        opacity: 0;
        transform: translateY(60px) scale(0.96);
    }

    100% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@keyframes nodeRipple {
    0% {
        transform: scale(1);
        opacity: 0.8;
    }

    100% {
        transform: scale(1.15, 1.25);
        opacity: 0;
    }
}

@keyframes cardSwingY {
    0% {
        opacity: 0;
        transform: translateY(50px) scale(0.95);
    }

    60% {
        transform: translateY(-5px) scale(1.02);
    }

    100% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@keyframes glitchShake {

    0%,
    100% {
        transform: translate(0, 0);
    }

    20% {
        transform: translate(-2px, 1px);
    }

    40% {
        transform: translate(1px, -1px);
    }

    60% {
        transform: translate(-1px, -1px);
    }

    80% {
        transform: translate(2px, 1px);
    }
}

@keyframes slideInFromOuter {
    0% {
        opacity: 0;
        transform: translateX(-50px);
    }

    100% {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes slideInFromInner {
    0% {
        opacity: 0;
        transform: translateX(50px);
    }

    100% {
        opacity: 1;
        transform: translateX(0);
    }
}

@keyframes rotateAurora {
    0% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }
}

@keyframes compressLetterReveal {
    0% {
        letter-spacing: 0.25em;
        filter: blur(5px);
        opacity: 0;
    }

    100% {
        letter-spacing: 0.02em;
        filter: blur(0);
        opacity: 1;
    }
}

@keyframes connectionFlow {
    0% {
        top: -20px;
        opacity: 0;
    }

    30% {
        opacity: 1;
    }

    70% {
        opacity: 1;
    }

    100% {
        top: 100%;
        opacity: 0;
    }
}

@keyframes metricPop {
    0% {
        opacity: 0;
        transform: translateY(40px) scale(0.9);
    }

    60% {
        transform: translateY(-5px) scale(1.02);
    }

    100% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

