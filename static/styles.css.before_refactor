.alert-card-container.alert-info {
    background: rgba(59, 130, 246, 0.05);
    border-color: rgba(59, 130, 246, 0.35);
    box-shadow: 0 0 40px rgba(59, 130, 246, 0.2);
    animation: scaleIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards, alertFloatInfo 5s ease-in-out infinite 0.8s;
}

/* Float Animations for Alert Cards */
@keyframes alertFloatDanger {
    0% {
        transform: translateY(0px) scale(1);
        box-shadow: 0 0 40px rgba(239, 68, 68, 0.15);
    }

    50% {
        transform: translateY(-8px) scale(1.005);
        box-shadow: 0 12px 50px rgba(239, 68, 68, 0.35);
        border-color: rgba(239, 68, 68, 0.5);
    }

    100% {
        transform: translateY(0px) scale(1);
        box-shadow: 0 0 40px rgba(239, 68, 68, 0.15);
    }
}

@keyframes alertFloatWarning {
    0% {
        transform: translateY(0px) scale(1);
        box-shadow: 0 0 40px rgba(245, 158, 11, 0.15);
    }

    50% {
        transform: translateY(-8px) scale(1.005);
        box-shadow: 0 12px 50px rgba(245, 158, 11, 0.35);
        border-color: rgba(245, 158, 11, 0.5);
    }

    100% {
        transform: translateY(0px) scale(1);
        box-shadow: 0 0 40px rgba(245, 158, 11, 0.15);
    }
}

@keyframes alertFloatInfo {
    0% {
        transform: translateY(0px) scale(1);
        box-shadow: 0 0 40px rgba(59, 130, 246, 0.15);
    }

    50% {
        transform: translateY(-8px) scale(1.005);
        box-shadow: 0 12px 50px rgba(59, 130, 246, 0.35);
        border-color: rgba(59, 130, 246, 0.5);
    }

    100% {
        transform: translateY(0px) scale(1);
        box-shadow: 0 0 40px rgba(59, 130, 246, 0.15);
    }
}

/* Hacker Code Highlight Styles */
.alert-code-highlight {
    background: rgba(0, 0, 0, 0.35);
