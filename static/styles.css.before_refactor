    animation: premiumTextReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.split-header h2 {
    font-size: 64px;
    font-weight: 800;
    background: linear-gradient(135deg, #FFFFFF 40%, var(--gold-secondary) 100%);
