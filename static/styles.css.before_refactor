    justify-content: center;
    gap: 20px;
    border-radius: 12px;
}

.export-spinner {
    width: 76px;
    height: 76px;
    border: 4px solid rgba(245, 158, 11, 0.1);
    border-top: 4px solid var(--gold-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }
}

.export-text-area {
    text-align: center;
    max-width: 400px;
}

.export-text-area h4 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--gold-secondary);
    margin-bottom: 8px;
}

.export-text-area p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 16px;
}

.progress-bar-container {
    width: 100%;
    height: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    overflow: hidden;
}

.progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold-primary), #D97706);
    width: 0%;
    transition: width 0.2s ease;
}

/* Scrollbars */
::-webkit-scrollbar {
    width: 6px;
    height: 6px;
}

::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.1);
}

::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--border-color-hover);
}

/* --- TikTok UI Simulator Styles --- */
.tiktok-ui-simulator {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    pointer-events: none;
    /* Let user click items underneath */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-family: sans-serif;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.6);
}

.tiktok-sim-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 60px 40px 20px 40px;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4) 0%, transparent 100%);
}

.sim-tabs {
    display: flex;
    gap: 30px;
    font-size: 26px;
    font-weight: 700;
}

.sim-tabs span {
    opacity: 0.6;
    position: relative;
    padding-bottom: 6px;
}

.sim-tabs span.active {
    opacity: 1;
}

.sim-tabs span.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 4px;
    background-color: #fff;
    border-radius: 2px;
}

.tiktok-sim-top i {
    opacity: 0.8;
}

/* Right Side Menu */
.tiktok-sim-right {
    position: absolute;
    right: 30px;
    bottom: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 35px;
}

.sim-avatar {
    position: relative;
    margin-bottom: 10px;
}

.avatar-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: #555;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 32px;
}

.avatar-plus {
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: #FE2C55;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: bold;
    border: 2px solid #fff;
}

.sim-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
}

.sim-action span {
    font-size: 24px;
    font-weight: 600;
}

.sim-disc-wrapper {
    width: 85px;
    height: 85px;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: rotateVinyl 4s linear infinite;
    margin-top: 10px;
}

.sim-disc-vinyl {
    font-size: 55px;
}

@keyframes rotateVinyl {
    0% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }
}

/* Bottom Caption Details */
.tiktok-sim-bottom {
    position: absolute;
    bottom: 140px;
    left: 40px;
    right: 170px;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.sim-username {
    font-size: 40px;
    font-weight: 700;
}

.sim-caption {
    font-size: 22px;
    line-height: 1.4;
    word-break: keep-all;
    overflow-wrap: break-word;
    text-wrap: pretty;
}

.sim-music {
    display: flex;
    align-items: center;
    font-size: 26px;
    font-weight: 500;
    max-width: 300px;
    overflow: hidden;
    white-space: nowrap;
}

.music-marquee {
    display: inline-block;
    animation: marqueeText 10s linear infinite;
    padding-left: 100%;
}

@keyframes marqueeText {
    0% {
        transform: translate3d(0, 0, 0);
    }

    100% {
        transform: translate3d(-100%, 0, 0);
    }
}

/* Bottom Navigation Bar */
.tiktok-sim-footer {
    display: flex;
    justify-content: space-around;
    align-items: center;
    height: 110px;
    background-color: rgba(0, 0, 0, 0.85);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0 20px;
}

.footer-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0.65;
    font-size: 22px;
}

.footer-tab.active {
    opacity: 1;
}

.footer-add-btn {
    width: 85px;
    height: 55px;
    background-color: #fff;
    border-radius: 12px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.footer-add-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -6px;
    width: 85px;
    height: 55px;
    background-color: #00f2fe;
    border-radius: 12px;
    z-index: -1;
}

.footer-add-btn::after {
    content: '';
    position: absolute;
    top: 0;
    right: -6px;
    width: 85px;
    height: 55px;
    background-color: #fe2c55;
    border-radius: 12px;
    z-index: -2;
}

.add-plus {
    color: #000;
    font-size: 36px;
    font-weight: 800;
}

/* Custom Slide Audio Player Widget */
.slide-audio-player-container {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 12px;
    margin-top: 12px;
    animation: scaleIn 0.3s ease;
}

.audio-player-status {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    margin-bottom: 8px;
}

.audio-badge {
    color: var(--success-green);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}

.audio-duration {
    color: var(--text-muted);
}

.audio-player-row {
    display: flex;
    align-items: center;
    gap: 8px;
}

audio.custom-audio-widget {
    flex: 1;
    height: 32px;
    border-radius: 4px;
    background-color: rgba(0, 0, 0, 0.4);
    outline: none;
}

/* Style the native audio player in Webkit browsers to match dark mode */
audio.custom-audio-widget::-webkit-media-controls-enclosure {
    background-color: rgba(13, 13, 17, 0.95);
    border: 1px solid var(--border-color);
    border-radius: 6px;
}

audio.custom-audio-widget::-webkit-media-controls-panel {
    background-color: transparent;
}

audio.custom-audio-widget::-webkit-media-controls-play-button,
audio.custom-audio-widget::-webkit-media-controls-mute-button,
audio.custom-audio-widget::-webkit-media-controls-timeline,
audio.custom-audio-widget::-webkit-media-controls-current-time-display,
audio.custom-audio-widget::-webkit-media-controls-time-remaining-display {
    filter: invert(1) hue-rotate(180deg) brightness(1.2);
    /* Make controls white/gold-ish */
}

/* --- Large Slide Icons in Title Layout --- */
.title-slide-icon-wrapper {
    width: 200px;
    height: 200px;
    background: rgba(245, 158, 11, 0.08);
    border: 2px solid rgba(245, 158, 11, 0.25);
    border-radius: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-primary);
    margin: 0 auto 40px auto;
    box-shadow: 0 15px 35px rgba(245, 158, 11, 0.15), inset 0 2px 10px rgba(245, 158, 11, 0.1);
    backdrop-filter: blur(10px);
    opacity: 0;
    animation: springDrop 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards, floatIcon 6s ease-in-out infinite 1.2s;
}

.title-slide-icon-wrapper svg {
    width: 100px;
    height: 100px;
    filter: drop-shadow(0 4px 8px rgba(245, 158, 11, 0.3));
}

@keyframes floatIcon {

    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-8px);
    }
}

/* --- Slide Headers Icon Box (Code, Diagram, Cards) --- */
.slide-header-icon-box {
    display: flex;
