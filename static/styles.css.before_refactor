    height: 2px;
    width: 100%;
    border-top: 2px dashed rgba(255, 255, 255, 0.15);
    top: 50%;
    left: 0;
    transform: translateY(-50%);
}

.sim-flow-arrow.active {
    color: var(--gold-primary);
}

.sim-flow-arrow.active::before {
    border-top-color: var(--gold-primary);
}

.sim-moving-packet {
    position: absolute;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--gold-primary);
    box-shadow: 0 0 10px var(--gold-primary);
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
}

.sim-flow-arrow.active .sim-moving-packet {
    animation: simPacketMove 1.0s linear infinite;
}

/* Scene 3 & 6: Overload & Hardware indicators */
.sim-telemetry-box {
    width: 100%;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.sim-meter-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.sim-meter-info {
    display: flex;
    justify-content: space-between;
    font-size: 30px;
    font-weight: 600;
}

.sim-meter-bar-container {
    width: 100%;
    height: 32px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    overflow: hidden;
}

.sim-meter-fill {
    height: 100%;
    width: 0%;
    border-radius: 999px;
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.4s ease;
}

.sim-meter-fill.normal {
    background: var(--success-green);
}

.sim-meter-fill.warning {
    background: var(--gold-primary);
}

.sim-meter-fill.danger {
    background: #ef4444;
    box-shadow: 0 0 8px #ef4444;
}

/* Scene 4: Internal Request Unfolding Cards */
.sim-requests-unfolder {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 90%;
    max-width: 880px;
}

.sim-unfold-card {
    border: 2px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(22, 22, 28, 0.8);
    overflow: hidden;
    transition: all 0.4s ease;
}

.sim-unfold-card.active {
    border-color: var(--gold-primary);
    box-shadow: 0 10px 30px rgba(245, 158, 11, 0.15);
}

.sim-unfold-header {
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 255, 255, 0.02);
}

.sim-unfold-title {
    font-size: 32px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
}

.sim-unfold-body {
    padding: 0 20px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), padding 0.4s ease;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.sim-unfold-card.expanded .sim-unfold-body {
    padding: 16px 20px;
    max-height: 300px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.sim-subtask-item {
    display: flex;
    justify-content: space-between;
    font-size: 28px;
    background: rgba(255, 255, 255, 0.03);
    padding: 16px 24px;
    border-radius: 6px;
    border-left: 3px solid var(--gold-primary);
}

.sim-subtask-item.heavy {
    border-left-color: #ef4444;
}

.sim-subtask-time {
    font-family: var(--font-mono);
    font-weight: bold;
    color: var(--gold-secondary);
}

/* Scene 5: Connection Pool bottleneck */
.sim-pool-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
    width: 100%;
}

.sim-pool-grid-box {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: 16px;
    background: rgba(0, 0, 0, 0.4);
    padding: 30px;
    border-radius: 16px;
    border: 2px solid rgba(255, 255, 255, 0.06);
    width: 100%;
    max-width: 820px;
    justify-items: center;
    align-items: center;
}

.sim-pool-dot {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
}

.sim-pool-dot.active {
    background: var(--success-green);
    box-shadow: 0 0 8px var(--success-green);
}

.sim-pool-dot.danger {
    background: #ef4444;
    box-shadow: 0 0 8px #ef4444;
}

.sim-queue-stack-box {
    width: 100%;
    max-width: 820px;
    background: rgba(239, 68, 68, 0.05);
    border: 2px dashed #ef4444;
    border-radius: 12px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.sim-stack-title {
    font-size: 32px;
    font-weight: 700;
    color: #ef4444;
}

.sim-stack-item {
    width: 100%;
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    padding: 16px 24px;
    text-align: center;
    border-radius: 8px;
    font-size: 32px;
    color: #f87171;
    font-weight: 600;
}

/* Scene 6: Domino fall animation */
.sim-domino-flow {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 30px;
    height: 300px;
    width: 100%;
    padding-bottom: 20px;
}

.sim-domino-tile {
    width: 100px;
    height: 200px;
    background: rgba(245, 158, 11, 0.08);
    border: 3px solid var(--gold-primary);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 28px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform-origin: bottom right;
}

.sim-domino-tile.active {
    background: rgba(245, 158, 11, 0.15);
}

.sim-domino-tile.fell {
    transform: rotate(70deg);
    border-color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
}

.sim-domino-tile.fell i {
    color: #ef4444;
    animation: pulseIcon 0.8s infinite;
}

/* Scene 9: Bank Simulator */
.sim-bank-lobby {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    width: 100%;
}

.sim-bank-tellers {
    display: flex;
    justify-content: space-around;
    width: 100%;
}

.sim-teller-desk {
    width: 240px;
    padding: 30px;
    background: rgba(255, 255, 255, 0.03);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    text-align: center;
    position: relative;
}

.sim-teller-desk.active {
    border-color: var(--success-green);
    background: rgba(16, 185, 129, 0.04);
}

.sim-teller-desk i {
    font-size: 54px;
    color: var(--text-muted);
}

.sim-teller-desk.active i {
    color: var(--success-green);
}

.sim-waiting-chairs {
    display: flex;
    gap: 15px;
    background: rgba(0, 0, 0, 0.3);
    padding: 30px 20px;
    border-radius: 12px;
    width: 90%;
    justify-content: center;
}

.sim-waiting-ticket {
    background: rgba(245, 158, 11, 0.12);
    border: 2px solid var(--gold-primary);
    border-radius: 8px;
    padding: 14px 20px;
    font-size: 28px;
    font-weight: bold;
    text-align: center;
    color: var(--gold-secondary);
    animation: floatSimCard 3s ease-in-out infinite;
}

/* Scene 12: Slow Worker Snail */
.sim-snail-track-container {
    width: 90%;
    max-width: 750px;
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 40px 24px;
    position: relative;
    overflow: hidden;
}

.sim-snail-track {
    width: 100%;
    height: 10px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 99px;
    position: relative;
}

.sim-snail-progress {
    height: 100%;
    background: var(--gold-primary);
    border-radius: 99px;
    width: 10%;
}

.sim-snail-sprite {
    position: absolute;
    top: -50px;
    left: 10%;
    transform: translateX(-50%);
    font-size: 72px;
    transition: left 0.4s ease;
    animation: snailWiggle 1.5s infinite ease-in-out;
}

.sim-snail-jobs-badge {
    font-weight: 800;
    color: #ef4444;
    font-size: 32px;
    animation: alertPopStatic 1s infinite alternate;
}

.sim-snail-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    width: 100%;
}

@keyframes alertPopStatic {
    0% {
        transform: scale(0.9);
    }

    100% {
        transform: scale(1.05);
    }
}

/* Animations */
@keyframes floatSimCard {
    0% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-8px);
    }

    100% {
        transform: translateY(0);
    }
}

@keyframes alertPop {
    0% {
        transform: translate(-50%, -50%) scale(0.9);
    }

    100% {
        transform: translate(-50%, -50%) scale(1.05);
    }
}

@keyframes simPacketMove {
    0% {
        left: 0;
        opacity: 0;
    }

    10% {
        opacity: 1;
    }

    90% {
        opacity: 1;
    }

    100% {
        left: 100%;
        opacity: 0;
    }
}

@keyframes shakeNode {
    0% {
        transform: translate(1px, 1px) rotate(0deg);
    }

    10% {
        transform: translate(-1px, -2px) rotate(-1deg);
    }

    20% {
        transform: translate(-3px, 0px) rotate(1deg);
    }

    30% {
        transform: translate(0px, 2px) rotate(0deg);
    }

    40% {
        transform: translate(1px, -1px) rotate(1deg);
    }

    50% {
        transform: translate(-1px, 2px) rotate(-1deg);
    }

    60% {
        transform: translate(-3px, 1px) rotate(0deg);
    }

    70% {
        transform: translate(2px, 1px) rotate(-1deg);
    }

    80% {
        transform: translate(-1px, -1px) rotate(1deg);
    }

    90% {
        transform: translate(2px, 2px) rotate(0deg);
    }

    100% {
        transform: translate(1px, -2px) rotate(-1deg);
    }
}

@keyframes snailWiggle {
    0% {
        transform: translateX(-50%) rotate(0deg);
    }

    50% {
        transform: translateX(-50%) rotate(4deg) translateY(-2px);
    }

    100% {
        transform: translateX(-50%) rotate(0deg);
    }
}


/* --- Video 1 (N+1 Query) Custom Simulations CSS --- */

.sim-n1-intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 30px;
    height: 100%;
    width: 100%;
}

.sim-monster-container {
    position: relative;
    width: 200px;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.sim-monster-eye {
    width: 140px;
    height: 140px;
    background: radial-gradient(circle, #ff0055 0%, #7a0022 70%, #1a0006 100%);
