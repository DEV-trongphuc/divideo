/* ==========================================================================
   Spotify Algorithm Custom Simulations
   ========================================================================== */
.spotify-phone-mockup {
    border: 2px solid rgba(245, 158, 11, 0.4) !important;
    background: radial-gradient(circle at top left, #202b26 0%, #121212 70%) !important;
}

@keyframes rain-fall {
    from {
        background-position: 0 0;
    }

    to {
        background-position: 0 200px;
    }
}

.rainy-overlay {
    animation: rain-fall 4s linear infinite;
}

.vinyl-disc-s1 {
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.7);
}

.mood-card-s1 {
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
    transition: transform 0.3s ease;
}

.mood-card-s1:hover {
    transform: translateY(-2px);
}

.active-user {
    animation: user-glow 2.5s infinite ease-in-out;
}

@keyframes user-glow {

    0%,
    100% {
        border-color: #1db954;
        box-shadow: 0 0 20px rgba(29, 185, 84, 0.15);
    }

    50% {
        border-color: #1ed760;
        box-shadow: 0 0 35px rgba(29, 185, 84, 0.45);
    }
}

/* Venn Diagram Styles */
.venn-circle {
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
}

.left-venn {
    border-color: #1db954 !important;
}

.right-venn {
    border-color: var(--gold-primary) !important;
}

.recommend-line {
    stroke-dasharray: 8 5;
    animation: flowLineAnim 1.5s linear infinite;
}

/* Crawler Box */
.crawler-text-box strong {
    font-weight: bold;
}

.kw-tag {
    transition: all 0.3s ease;
}

/* Audio Spectrogram Waveform */
.wave-bar {
    transition: all 0.15s ease-in-out;
}

.wave-scanner {
    transition: left 0.1s linear;
}

/* Attractor effect rings */
.attract-ring {
    animation: attract-ring-expand 2s infinite linear;
}

@keyframes attract-ring-expand {
    0% {
        transform: translate(-68px, -68px) scale(0.6);
        opacity: 0.8;
    }

    100% {
        transform: translate(-68px, -68px) scale(1.4);
        opacity: 0;
    }
}

/* 3D floating nodes in space */
@keyframes floatNodeY {

    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-10px);
    }
}

.pt-node {
    animation: floatNodeY 4s infinite ease-in-out;
}

.pt-node.p1 {
    animation-delay: 0.2s;
}

.pt-node.p2 {
    animation-delay: 0.8s;
}

.pt-node.p3 {
    animation-delay: 1.4s;
}

.pt-node.p4 {
    animation-delay: 2s;
}


